# Copy to .env and fill in. Load with `set -a; source .env; set +a` or use direnv.

# RapidAPI - from https://rapidapi.com after subscribing to Stock Screener
RAPIDAPI_KEY=
RAPIDAPI_HOST=

# Alpaca paper-trading - from https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# Optional kill switch - set to any non-empty value to skip rebalancing
# BOT_DISABLED=1
